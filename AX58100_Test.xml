<?xml version="1.0" encoding="UTF-8"?>
<!--
  AX58100_Test.xml — ESI 从站描述文件
  基于 SSC-IO.xml 结构, 适配 AX58100 + STM32F103
  日期: 2026-06-20
-->
<EtherCATInfo Version="1.1">
  <Vendor>
    <Id>1430</Id><!-- 0x00000596 -->
    <Name>AX58100_Test Vendor</Name>
  </Vendor>
  <Descriptions>
    <Groups>
      <Group SortOrder="100">
        <Type>AX58100_Test</Type>
        <Name>AX58100 测试从站</Name>
      </Group>
    </Groups>
    <Devices>
      <Device Physics="YY">
        <Type ProductCode="#x58100000" RevisionNo="#x00020111">AX58100_Test</Type>
        <Name>AX58100 EtherCAT 测试从站</Name>

        <!-- ════════════════════════════════════════════════
             状态机超时 / 邮箱超时
             ════════════════════════════════════════════════ -->
        <Info>
          <StateMachine>
            <Timeout>
              <PreopTimeout>2000</PreopTimeout>
              <SafeopOpTimeout>9000</SafeopOpTimeout>
              <BackToInitTimeout>5000</BackToInitTimeout>
              <BackToSafeopTimeout>200</BackToSafeopTimeout>
            </Timeout>
          </StateMachine>
          <Mailbox>
            <Timeout>
              <RequestTimeout>100</RequestTimeout>
              <ResponseTimeout>2000</ResponseTimeout>
            </Timeout>
          </Mailbox>
        </Info>

        <GroupType>AX58100_Test</GroupType>

        <!-- ════════════════════════════════════════════════
             SyncManager
             ════════════════════════════════════════════════ -->
        <Sm MinSize="34" MaxSize="128" DefaultSize="128"
            StartAddress="#x1000" ControlByte="#x26" Enable="1">MBoxOut</Sm>
        <Sm MinSize="34" MaxSize="128" DefaultSize="128"
            StartAddress="#x1080" ControlByte="#x22" Enable="1">MBoxIn</Sm>
        <Sm DefaultSize="32" StartAddress="#x1100"
            ControlByte="#x64" Enable="1">Outputs</Sm>
        <Sm DefaultSize="32" StartAddress="#x1120"
            ControlByte="#x20" Enable="1">Inputs</Sm>

        <!-- ════════════════════════════════════════════════
             FMMU
             ════════════════════════════════════════════════ -->
        <Fmmu>Outputs</Fmmu>
        <Fmmu>Inputs</Fmmu>
        <Fmmu>MBoxState</Fmmu>

        <!-- ════════════════════════════════════════════════
             RxPDO (主站→从站, SM2)
             ════════════════════════════════════════════════ -->
        <RxPdo Mandatory="true" Fixed="true" Sm="2">
          <Index>#x1600</Index>
          <Name>RxPDO</Name>
          <Entry>
            <Index>#x2000</Index>
            <SubIndex>0</SubIndex>
            <BitLen>32</BitLen>
            <Name>Test Counter</Name>
            <DataType>UDINT</DataType>
          </Entry>
        </RxPdo>

        <!-- ════════════════════════════════════════════════
             TxPDO (从站→主站, SM3)
             ════════════════════════════════════════════════ -->
        <TxPdo Mandatory="true" Fixed="true" Sm="3">
          <Index>#x1a00</Index>
          <Name>TxPDO</Name>
          <Entry>
            <Index>#x2001</Index>
            <SubIndex>0</SubIndex>
            <BitLen>32</BitLen>
            <Name>Test Status</Name>
            <DataType>UDINT</DataType>
          </Entry>
        </TxPdo>

        <!-- ════════════════════════════════════════════════
             Mailbox / CoE
             ════════════════════════════════════════════════ -->
        <Mailbox DataLinkLayer="true">
          <CoE SdoInfo="true" />
        </Mailbox>

        <!-- ════════════════════════════════════════════════
             EEPROM
             ════════════════════════════════════════════════ -->
        <Eeprom>
          <ByteSize>2048</ByteSize>
          <ConfigData>050E03440A0000000000</ConfigData>
        </Eeprom>

      </Device>
    </Devices>
  </Descriptions>
</EtherCATInfo>
